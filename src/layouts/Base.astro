---
import '../styles/global.css';
const { title = 'Jeffry Arevalo', description = 'Data journalist, analyst, and builder' } = Astro.props;
const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <header class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">Jeffry Arevalo</a>
      <nav>
        <ul class="nav-links">
          <li><a href="/projects" class:list={[{active: currentPath.startsWith('/projects')}]}>Projects</a></li>
          <li><a href="/publications" class:list={[{active: currentPath.startsWith('/publications')}]}>Publications</a></li>
          <li><a href="/content" class:list={[{active: currentPath.startsWith('/content')}]}>Content</a></li>
          <li><a href="/about" class:list={[{active: currentPath === '/about'}]}>About</a></li>
          <li><a href="/contact" class:list={[{active: currentPath === '/contact'}]}>Contact</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <p>© {new Date().getFullYear()} Jeffry Arevalo · Built with Astro · Hosted on Netlify</p>
  </footer>
</body>
</html>
