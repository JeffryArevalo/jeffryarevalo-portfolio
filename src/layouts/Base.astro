---
import '../styles/global.css';

const {
  title       = 'Jeffry Arevalo — Data Journalist & Builder',
  description = 'Data journalist, analyst, and builder working at the intersection of data investigation, AI automation, and software development.',
  ogImage     = '/images/pub-ai-race.jpg',
} = Astro.props;

const currentPath = Astro.url.pathname;
const siteUrl     = Astro.site ?? new URL('https://jeffryarevalo.com');
const canonicalURL = new URL(currentPath, siteUrl).toString();
const ogImageURL   = new URL(ogImage, siteUrl).toString();
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Primary -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:site_name"   content="Jeffry Arevalo" />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImageURL} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale"      content="en_US" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImageURL} />
</head>
<body>
  <header class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="Jeffry Arevalo — Home">
        <img src="/images/logo.png" alt="" class="nav-logo-img" />
        <span class="nav-brand-name">Jeffry Arevalo</span>
      </a>
      <nav>
        <ul class="nav-links">
          <li><a href="/" class:list={[{active: currentPath === '/'}]}>Home</a></li>
          <li><a href="/projects" class:list={[{active: currentPath.startsWith('/projects')}]}>Projects</a></li>
          <li><a href="/publications" class:list={[{active: currentPath.startsWith('/publications')}]}>Publications</a></li>
          <li><a href="/content" class:list={[{active: currentPath.startsWith('/content')}]}>Content</a></li>
          <li><a href="/about" class:list={[{active: currentPath === '/about'}]}>About</a></li>
          <li><a href="/contact" class:list={[{active: currentPath === '/contact'}]}>Contact</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <img src="/images/logo.png" alt="Jeffry Arevalo" class="footer-logo" />
    <p>© {new Date().getFullYear()} Jeffry Arevalo · Built with Astro · Hosted on Netlify</p>
  </footer>
</body>
</html>
