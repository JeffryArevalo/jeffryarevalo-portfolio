---
import Base from '../layouts/Base.astro';

const platforms = [
  {
    name: 'Tableau',
    handle: 'Public Profile',
    url: 'https://public.tableau.com/app/profile/jeffry.alejandro.arevalo.jurado/vizzes',
    desc: 'Interactive data visualizations — dashboards, charts, and exploratory analyses published on Tableau Public.',
    cta: 'View Vizzes ↗',
    icon: 'chart',
  },
  {
    name: 'YouTube',
    handle: '@BodyExplained-f5b',
    url: 'https://www.youtube.com/@BodyExplained-f5b',
    desc: 'Educational content exploring the human body — built with an AI-powered content pipeline from scripting to publishing.',
    cta: 'Visit Channel ↗',
    icon: 'youtube',
  },
  {
    name: 'Instagram',
    handle: '@soulvra',
    url: 'https://www.instagram.com/soulvra/',
    desc: 'AI-powered social content — automated generation, caption writing, and scheduled posting through a custom automation stack.',
    cta: '@soulvra ↗',
    icon: 'instagram',
  },
];
---

<Base title="Content — Jeffry Arevalo" description="Data visualizations on Tableau Public, educational video on YouTube, and content on Instagram.">
  <div class="page">

    <div class="page-header">
      <h1>Content & Platforms</h1>
      <p>
        Data visualizations on Tableau Public, educational video on YouTube, and social content on Instagram.
      </p>
    </div>

    <div class="platform-grid">
      {platforms.map(p => (
        <div class="platform-block">
          <div class="platform-block-header">
            <div class="platform-icon-wrap">
              {p.icon === 'chart' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M8 16V11M12 16V8M16 16V13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              )}
              {p.icon === 'youtube' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <rect x="2" y="5" width="20" height="14" rx="4" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M10 9.5l5 2.5-5 2.5V9.5z" fill="currentColor"/>
                </svg>
              )}
              {p.icon === 'instagram' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5"/>
                  <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/>
                  <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
                </svg>
              )}
            </div>
            <div>
              <h2 class="platform-name">{p.name}</h2>
              <p class="platform-handle">{p.handle}</p>
            </div>
          </div>
          <p class="platform-desc">{p.desc}</p>
          <a href={p.url} target="_blank" rel="noopener noreferrer" class="btn btn-outline platform-cta">
            {p.cta}
          </a>
        </div>
      ))}
    </div>

  </div>
</Base>

<style>
.page-header { margin-bottom: 3rem; }
.page-header h1 { font-size: 2.25rem; margin-bottom: 0.5rem; }
.page-header p { color: var(--text-secondary); font-size: 1.0625rem; max-width: 560px; line-height: 1.7; }

.platform-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.25rem;
}

.platform-block {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.5rem;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  gap: 1rem;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.platform-block:hover {
  border-color: var(--border-strong);
  box-shadow: var(--shadow-card-hover);
}

.platform-block-header {
  display: flex;
  align-items: center;
  gap: 0.875rem;
}

.platform-icon-wrap {
  width: 44px;
  height: 44px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--border);
  background: var(--accent-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.platform-name {
  font-family: var(--font-serif);
  font-size: 1.1rem;
  color: var(--text-primary);
  line-height: 1.2;
}

.platform-handle {
  font-size: 0.8125rem;
  color: var(--text-tertiary);
  margin-top: 0.15rem;
}

.platform-desc {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.65;
  flex: 1;
}

.platform-cta {
  align-self: flex-start;
}

@media (max-width: 768px) {
  .platform-grid { grid-template-columns: 1fr; }
}
</style>
