---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Base title="Publications — Jeffry Arevalo" description="Data investigations, essays, and insights on AI, economics, and the future of work.">
  <div class="page-narrow">

    <div class="page-header">
      <h1>Publications</h1>
      <p>Data investigations, essays, and insights on AI, economics, and the future of work.</p>
    </div>

    <div class="pub-list">
      {posts.map(post => (
        <a
          href={post.data.externalUrl ?? `/publications/${post.id}`}
          target={post.data.externalUrl ? '_blank' : undefined}
          rel={post.data.externalUrl ? 'noopener noreferrer' : undefined}
          class="pub-card"
        >
          {post.data.image && (
            <div class="pub-card-img-wrap">
              <img src={post.data.image} alt={post.data.title} class="pub-card-img" />
            </div>
          )}
          <div class="pub-card-body">
            <div class="pub-card-top">
              <span class="blog-card-date">
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
              {post.data.externalUrl && <span class="external-badge">Full Investigation ↗</span>}
            </div>
            <h2 class="blog-card-title">{post.data.title}</h2>
            <p class="blog-card-desc">{post.data.description}</p>
            {post.data.tags && (
              <div class="blog-card-tags">
                {post.data.tags.map(tag => <span class="blog-tag">{tag}</span>)}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>

  </div>
</Base>

<style>
.page-header { margin-bottom: 2.5rem; }
.page-header h1 { font-size: 2.25rem; margin-bottom: 0.5rem; }
.page-header p { color: var(--text-secondary); font-size: 1.0625rem; }

.pub-list { display: flex; flex-direction: column; gap: 1.25rem; }

.pub-card {
  display: flex;
  flex-direction: column;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
}
.pub-card:hover {
  border-color: var(--border-strong);
  box-shadow: var(--shadow-lift);
  transform: translateY(-2px);
}

.pub-card-img-wrap {
  width: 100%;
  aspect-ratio: 16 / 7;
  overflow: hidden;
  background: var(--surface-raised);
  flex-shrink: 0;
}
.pub-card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top;
  display: block;
  transition: transform 0.4s ease;
}
.pub-card:hover .pub-card-img { transform: scale(1.02); }

.pub-card-body {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.pub-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.external-badge {
  font-size: 0.7rem;
  font-weight: 500;
  padding: 2px 8px;
  border-radius: 999px;
  background: var(--accent-muted);
  color: var(--text-secondary);
  white-space: nowrap;
  flex-shrink: 0;
}
</style>
