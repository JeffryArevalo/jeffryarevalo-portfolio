---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const publications = allPosts
  .filter(p => p.data.externalUrl)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const aiRace = publications.find(p => p.id === 'ai-race');
const kEconomy = publications.find(p => p.id === 'k-shaped-economy');

const categoryClass = (cat: string) => {
  if (cat === 'Data Analysis') return 'badge-data';
  if (cat === 'AI / Automation') return 'badge-auto';
  if (cat === 'Software') return 'badge-software';
  return 'badge-viz';
};
---

<Base
  title="Jeffry Arevalo — Data Journalist & Builder"
  description="Data journalist, analyst, and builder. I investigate data, build systems, and publish what I find — from AI economics to labor market investigations."
>

  <!-- HERO -->
  <section class="hero">

    <!-- Animated grid overlay -->
    <div class="hero-grid" aria-hidden="true"></div>

    <!-- Radial glow -->
    <div class="hero-glow" aria-hidden="true"></div>

    <div class="hero-inner">

      <div class="hero-text">
        <p class="hero-eyebrow">Data Journalist · Analyst · Builder</p>
        <h1 class="hero-headline">
          I investigate<br/>
          <span class="hero-accent">data.</span><br/>
          I build systems.<br/>
          I publish what<br/>
          I find.
        </h1>
        <p class="hero-sub">
          Complex information turned into clear stories and tools.
          From in-depth data investigations to AI-powered automation,
          I work where data, technology, and communication meet.
        </p>
        <div class="hero-ctas">
          <a href="/publications" class="btn btn-primary">Read Publications</a>
          <a href="/projects" class="btn btn-outline">View Projects</a>
          <a href="/about" class="btn btn-ghost">About Me →</a>
        </div>
      </div>

      <div class="hero-showcase">

        <div class="hero-media">
          <video class="hero-video" autoplay loop muted playsinline poster="/images/pub-ai-race.jpg">
            <source src="/images/hero-animation.mp4" type="video/mp4" />
          </video>
        </div>

        <div class="showcase-chip">Latest Investigation</div>
        <div class="showcase-title">The AI Race: A Data Story</div>

        <div class="showcase-stats">
          <div class="showcase-stat">
            <span class="stat-num" data-target="2.52" data-suffix="T" data-prefix="$">$2.52T</span>
            <span class="stat-label">Global AI Spend</span>
          </div>
          <div class="showcase-stat">
            <span class="stat-num" data-target="81" data-suffix="%">81%</span>
            <span class="stat-label">VC into AI</span>
          </div>
          <div class="showcase-stat">
            <span class="stat-num" data-target="300" data-suffix="M">300M</span>
            <span class="stat-label">Jobs at Risk</span>
          </div>
        </div>

        <p class="showcase-desc">
          Who is really building artificial intelligence, what it is costing society,
          and where ordinary people stand in a race nobody asked for.
        </p>
        <a href="/publications/ai-race" class="showcase-link">
          Read the Investigation ↗
        </a>

      </div>

    </div>
  </section>

  <!-- FEATURED PUBLICATIONS -->
  <section class="pub-section" data-animate-section>
    <div class="section-inner">
      <div class="section-label-row">
        <span class="section-label">Publications</span>
        <a href="/publications" class="see-all">See all →</a>
      </div>

      <div class="pub-grid">

        {aiRace && (
          <a href="/publications/ai-race" class="pub-card pub-card-dark" data-animate-item>
            <div class="pub-card-img pub-card-img-dark">
              <img src="/images/pub-ai-race.jpg" alt="The AI Race" class="pub-img" onerror="this.style.display='none'" />
              <div class="pub-card-tags">
                {aiRace.data.tags?.slice(0, 2).map(t => <span class="pub-tag pub-tag-light">{t}</span>)}
              </div>
            </div>
            <div class="pub-card-body">
              <p class="pub-card-date">
                {aiRace.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
              </p>
              <h2 class="pub-card-title">{aiRace.data.title}</h2>
              <p class="pub-card-desc">{aiRace.data.description}</p>
              <span class="pub-card-cta">Read Investigation ↗</span>
            </div>
          </a>
        )}

        {kEconomy && (
          <a href="/publications/k-shaped-economy" class="pub-card pub-card-light" data-animate-item>
            <div class="pub-card-img pub-card-img-light">
              <img src="/images/pub-k-economy.jpg" alt="The K-Shaped Economy" class="pub-img" onerror="this.style.display='none'" />
              <div class="pub-card-tags">
                {kEconomy.data.tags?.slice(0, 2).map(t => <span class="pub-tag pub-tag-dark">{t}</span>)}
              </div>
            </div>
            <div class="pub-card-body">
              <p class="pub-card-date">
                {kEconomy.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
              </p>
              <h2 class="pub-card-title pub-card-title-dark">{kEconomy.data.title}</h2>
              <p class="pub-card-desc pub-card-desc-dark">{kEconomy.data.description}</p>
              <span class="pub-card-cta pub-card-cta-dark">Read Investigation ↗</span>
            </div>
          </a>
        )}

      </div>
    </div>
  </section>

  <!-- PLATFORMS -->
  <section class="platforms-section" data-animate-section>
    <div class="section-inner">
      <div class="section-label-row">
        <span class="section-label">Content & Platforms</span>
        <a href="/content" class="see-all">See more →</a>
      </div>

      <div class="platforms-row">

        <a href="https://public.tableau.com/app/profile/jeffry.alejandro.arevalo.jurado/vizzes"
           target="_blank" rel="noopener noreferrer"
           class="platform-pill" data-animate-item>
          <div class="platform-pill-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>
              <path d="M8 16V11M12 16V8M16 16V13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="platform-pill-text">
            <span class="platform-pill-name">Tableau Public</span>
            <span class="platform-pill-sub">Data visualizations</span>
          </div>
          <span class="platform-pill-arrow">↗</span>
        </a>

        <a href="https://www.youtube.com/@BodyExplained-f5b"
           target="_blank" rel="noopener noreferrer"
           class="platform-pill" data-animate-item>
          <div class="platform-pill-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <rect x="2" y="5" width="20" height="14" rx="4" stroke="currentColor" stroke-width="1.5"/>
              <path d="M10 9.5l5 2.5-5 2.5V9.5z" fill="currentColor"/>
            </svg>
          </div>
          <div class="platform-pill-text">
            <span class="platform-pill-name">YouTube</span>
            <span class="platform-pill-sub">@BodyExplained-f5b</span>
          </div>
          <span class="platform-pill-arrow">↗</span>
        </a>

        <a href="https://www.instagram.com/soulvra/"
           target="_blank" rel="noopener noreferrer"
           class="platform-pill" data-animate-item>
          <div class="platform-pill-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
            </svg>
          </div>
          <div class="platform-pill-text">
            <span class="platform-pill-name">Instagram</span>
            <span class="platform-pill-sub">@soulvra</span>
          </div>
          <span class="platform-pill-arrow">↗</span>
        </a>

      </div>
    </div>
  </section>

  <!-- FEATURED PROJECTS -->
  {featuredProjects.length > 0 && (
    <section class="projects-section" data-animate-section>
      <div class="section-inner">
        <div class="section-label-row">
          <span class="section-label">Featured Projects</span>
          <a href="/projects" class="see-all">See all →</a>
        </div>
        <div class="cards-grid">
          {featuredProjects.map(project => (
            <a href={`/projects/${project.id}`} class="project-card" data-animate-item data-category={project.data.category}>
              {project.data.image && (
                <div class="project-card-img-wrap">
                  <img src={project.data.image} alt={project.data.title} class="project-card-img" />
                </div>
              )}
              <div class="project-card-content">
                <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:0.25rem;">
                  <span class={`category-badge ${categoryClass(project.data.category)}`}>
                    {project.data.category}
                  </span>
                </div>
                <h3 class="project-card-title">{project.data.title}</h3>
                <p class="project-card-desc">{project.data.description}</p>
                <div class="project-card-footer">
                  <div class="tools-list">
                    {project.data.tools.slice(0, 3).map(tool => (
                      <span class="tool-tag">{tool}</span>
                    ))}
                  </div>
                  <div class="card-links">
                    {project.data.links?.github && <span class="card-link">GitHub ↗</span>}
                    {project.data.links?.tableau && <span class="card-link">Tableau ↗</span>}
                    {project.data.links?.live && <span class="card-link">Live ↗</span>}
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</Base>

<style>
/* ── Shared layout ─────────────────────────────────────────── */
.section-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 0 2rem;
}

.section-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1.75rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--border);
}

.section-label {
  font-size: 0.75rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-tertiary);
}

/* ── Hero ──────────────────────────────────────────────────── */
.hero {
  background: #080808;
  padding: 0 2rem;
  min-height: 100vh;
  display: flex;
  align-items: flex-start;
  position: relative;
  overflow: hidden;
}

/* Animated grid — matches AI Race hero technique */
.hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(200, 57, 43, 0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(200, 57, 43, 0.04) 1px, transparent 1px);
  background-size: 60px 60px;
  animation: gridPulse 8s ease-in-out infinite;
  pointer-events: none;
}

@keyframes gridPulse {
  0%, 100% { opacity: 0.4; }
  50%       { opacity: 1; }
}

/* Radial glow behind left text */
.hero-glow {
  position: absolute;
  width: 700px;
  height: 700px;
  border-radius: 50%;
  background: radial-gradient(ellipse, rgba(200, 57, 43, 0.07) 0%, transparent 70%);
  top: 50%;
  left: -10%;
  transform: translateY(-50%);
  pointer-events: none;
}

.hero-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: start;
  padding: clamp(3rem, 7vh, 4.5rem) 0 5rem;
  position: relative;
  z-index: 1;
}

.hero-eyebrow {
  font-size: 0.75rem;
  font-weight: 400;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: #c8392b;
  margin-bottom: 1.75rem;
  font-family: var(--font-sans);
}

.hero-headline {
  font-family: var(--font-serif);
  font-size: clamp(2.75rem, 5.5vw, 4.5rem);
  line-height: 1.05;
  color: #f0ece4;
  margin-bottom: 1.75rem;
  letter-spacing: -0.02em;
}

.hero-accent {
  color: #c8392b;
  font-style: italic;
}

.hero-sub {
  font-size: 1rem;
  color: #948f89;
  line-height: 1.8;
  max-width: 420px;
  margin-bottom: 2.5rem;
}

.hero-ctas {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.btn-ghost {
  font-size: 0.875rem;
  color: var(--text-tertiary);
  padding: 0.6rem 0.5rem;
  transition: color 0.15s;
  font-family: var(--font-sans);
}
.btn-ghost:hover { color: var(--text-primary); }

/* Hero showcase card */
.hero-showcase {
  background: #0f0f0f;
  border: 1px solid #2e2e2c;
  border-radius: 14px;
  padding: 0 2rem 2rem;
  color: #f0ece4;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  animation: fadeUp 0.7s ease both;
  animation-delay: 0.2s;
  overflow: hidden;
}

/* Hero media: Google Flow animation */
.hero-media {
  width: calc(100% + 4rem);
  margin-left: -2rem;
  height: 200px;
  background: #080808;
  border-bottom: 1px solid #2e2e2c;
  overflow: hidden;
  flex-shrink: 0;
  position: relative;
}

/* Gradient overlay darkens the video so it doesn't overpower the card */
.hero-media::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(8, 8, 8, 0.25) 0%,
    rgba(8, 8, 8, 0.55) 100%
  );
  pointer-events: none;
}

.hero-video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  opacity: 0.65;
}

.showcase-chip {
  display: inline-block;
  font-size: 0.675rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  padding: 3px 10px;
  border-radius: 999px;
  border: 1px solid #c8392b;
  color: #c8392b;
  align-self: flex-start;
  margin-top: 0.25rem;
}

.showcase-title {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  color: #f0ece4;
  line-height: 1.25;
}

.showcase-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.5rem;
  padding: 1.25rem 0;
  border-top: 1px solid #2e2e2c;
  border-bottom: 1px solid #2e2e2c;
}

.showcase-stat {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  background: rgba(200, 57, 43, 0.06);
  border-radius: 8px;
  padding: 0.7rem 0.6rem;
}

.stat-num {
  font-family: var(--font-serif);
  font-size: 1.4rem;
  color: #f0ece4;
  line-height: 1;
}

.stat-label {
  font-size: 0.675rem;
  color: #948f89;
  line-height: 1.3;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.showcase-desc {
  font-size: 0.875rem;
  color: #948f89;
  line-height: 1.7;
}

.showcase-link {
  font-size: 0.875rem;
  font-weight: 500;
  color: #c8392b;
  border-bottom: 1px solid rgba(200, 57, 43, 0.3);
  padding-bottom: 2px;
  align-self: flex-start;
  transition: border-color 0.15s, color 0.15s;
}
.showcase-link:hover { color: #e84234; border-color: #c8392b; }

/* ── Publications ─────────────────────────────────────────── */
.pub-section {
  padding: 5rem 0;
}

.pub-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
}

/* Both cards share the same dark surface — no jarring contrast between them */
.pub-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  box-shadow: var(--shadow-card);
}
.pub-card:hover {
  transform: translateY(-3px);
  border-color: var(--border-strong);
  box-shadow: var(--shadow-lift);
}

/* Modifier classes kept for HTML compatibility but visually unified */
.pub-card-dark {}
.pub-card-light {}

.pub-card-img {
  position: relative;
  height: 200px;
  overflow: hidden;
  flex-shrink: 0;
  background: #0a0a09;
}
.pub-card-img-dark { background: linear-gradient(135deg, #141412 0%, #1e1e1c 100%); }
.pub-card-img-light { background: linear-gradient(135deg, #141412 0%, #1e1e1c 100%); }

.pub-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  opacity: 0.85;
}

.pub-card-tags {
  position: absolute;
  bottom: 1rem;
  left: 1rem;
  display: flex;
  gap: 0.4rem;
}

.pub-tag {
  font-size: 0.675rem;
  font-weight: 500;
  padding: 2px 8px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.75);
}
.pub-tag-light { background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.75); }
.pub-tag-dark  { background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.75); }

.pub-card-body {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  flex: 1;
}

.pub-card-date      { font-size: 0.75rem; color: var(--text-tertiary); }
.pub-card-title     { font-family: var(--font-serif); font-size: 1.35rem; color: var(--text-primary); line-height: 1.25; }
.pub-card-title-dark {}
.pub-card-desc      { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.65; flex: 1; }
.pub-card-desc-dark {}

.pub-card-cta {
  font-size: 0.8125rem;
  font-weight: 500;
  color: var(--text-tertiary);
  margin-top: 0.5rem;
  transition: color 0.15s;
}
.pub-card-cta-dark {}
.pub-card:hover .pub-card-cta      { color: var(--accent); }
.pub-card-light:hover .pub-card-cta-dark {}

/* ── Platforms ────────────────────────────────────────────── */
.platforms-section {
  padding: 0 0 5rem;
}

.platforms-row {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.platform-pill {
  display: flex;
  align-items: center;
  gap: 1rem;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1rem 1.25rem;
  box-shadow: var(--shadow-card);
  transition: border-color 0.15s, box-shadow 0.15s;
  position: relative;
}
.platform-pill::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  bottom: 20%;
  width: 2px;
  border-radius: 2px;
  background: var(--text-primary);
  opacity: 0;
  transition: opacity 0.2s;
}
.platform-pill:hover {
  border-color: var(--border-strong);
  box-shadow: var(--shadow-card-hover);
}
.platform-pill:hover::before { opacity: 1; }

.platform-pill-icon {
  width: 38px;
  height: 38px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--border);
  background: var(--accent-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.platform-pill-text {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
  flex: 1;
}

.platform-pill-name {
  font-size: 0.9375rem;
  color: var(--text-primary);
  font-weight: 400;
}

.platform-pill-sub {
  font-size: 0.8125rem;
  color: var(--text-tertiary);
}

.platform-pill-arrow {
  color: var(--text-tertiary);
  font-size: 1rem;
  transition: color 0.15s;
}
.platform-pill:hover .platform-pill-arrow { color: var(--text-primary); }

/* ── Projects ─────────────────────────────────────────────── */
.projects-section {
  padding: 0 0 6rem;
}

.project-card-img-wrap {
  width: 100%;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  background: var(--surface-raised);
  flex-shrink: 0;
}
.project-card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top;
  display: block;
  transition: transform 0.5s ease;
}
.project-card:hover .project-card-img { transform: scale(1.04); }

.project-card-content {
  padding: 1.25rem 1.5rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  flex: 1;
}

.project-card[data-category="Data Visualization"] { border-top: 2px solid #6b21a8; }
.project-card[data-category="Data Analysis"]      { border-top: 2px solid #1a56db; }
.project-card[data-category="AI / Automation"]    { border-top: 2px solid #92400e; }
.project-card[data-category="Software"]           { border-top: 2px solid #065f46; }

/* ── Scroll-reveal ─────────────────────────────────────────── */
[data-animate-item] {
  opacity: 0;
  transform: translateY(22px);
  transition: opacity 0.55s ease, transform 0.55s ease;
}

[data-animate-item].is-visible {
  opacity: 1;
  transform: translateY(0);
}

/* ── Entry animations ─────────────────────────────────────── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

.hero-text {
  animation: fadeUp 0.7s ease both;
}

.hero-showcase {
  animation: fadeUp 0.7s ease both;
  animation-delay: 0.18s;
}

/* ── Responsive ───────────────────────────────────────────── */
@media (max-width: 900px) {
  .hero-inner {
    grid-template-columns: 1fr;
    gap: 3rem;
    padding: clamp(2.5rem, 6vh, 4rem) 0 4rem;
  }
  .hero { min-height: auto; }
  .pub-grid { grid-template-columns: 1fr; }
  .showcase-stats { grid-template-columns: repeat(3, 1fr); }
}

@media (max-width: 640px) {
  .hero-ctas { flex-direction: column; align-items: flex-start; }
  .section-inner { padding: 0 1.25rem; }
  .pub-section, .platforms-section { padding-top: 3.5rem; padding-bottom: 3.5rem; }
  .hero-headline { font-size: 2.5rem; }
}
</style>

<script>
  // Scroll-triggered entrance animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;

        const items = entry.target.querySelectorAll('[data-animate-item]');
        items.forEach((el, i) => {
          setTimeout(() => el.classList.add('is-visible'), i * 90);
        });

        if (entry.target.classList.contains('hero')) {
          startCounters();
        }

        observer.unobserve(entry.target);
      });
    },
    { threshold: 0.12 }
  );

  document.querySelectorAll('[data-animate-section]').forEach((s) => observer.observe(s));

  const heroEl = document.querySelector('.hero');
  if (heroEl) observer.observe(heroEl);

  // Animated number counters
  let countersStarted = false;

  function startCounters() {
    if (countersStarted) return;
    countersStarted = true;

    document.querySelectorAll<HTMLElement>('.stat-num[data-target]').forEach((el) => {
      const target = parseFloat(el.dataset.target ?? '0');
      const prefix = el.dataset.prefix ?? '';
      const suffix = el.dataset.suffix ?? '';
      const isDecimal = (el.dataset.target ?? '').includes('.');
      const steps = 50;
      const stepTime = 1400 / steps;
      let step = 0;

      const timer = setInterval(() => {
        step++;
        const progress = 1 - Math.pow(1 - step / steps, 3);
        const current = target * progress;
        el.textContent =
          prefix + (isDecimal ? current.toFixed(2) : String(Math.round(current))) + suffix;

        if (step >= steps) {
          clearInterval(timer);
          el.textContent =
            prefix + (isDecimal ? target.toFixed(2) : String(target)) + suffix;
        }
      }, stepTime);
    });
  }
</script>
