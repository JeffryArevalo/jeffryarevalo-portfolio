---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();

const categoryClass = (cat: string) => {
  if (cat === 'Data Analysis') return 'badge-data';
  if (cat === 'AI / Automation') return 'badge-auto';
  if (cat === 'Software') return 'badge-software';
  return 'badge-viz';
};
---

<Base title={`${project.data.title} — Jeffry Arevalo`} description={project.data.description}>
  <div class="page-narrow">

    <a href="/projects" class="back-link">← All Projects</a>

    <div class="project-header">
      <span class={`category-badge ${categoryClass(project.data.category)}`}>
        {project.data.category}
      </span>
      <h1 class="project-title">{project.data.title}</h1>
      <p class="project-desc">{project.data.description}</p>

      <div class="project-meta">
        <div>
          <p class="meta-label">Tools</p>
          <div class="tools-list">
            {project.data.tools.map(tool => <span class="tool-tag">{tool}</span>)}
          </div>
        </div>

        {project.data.links && Object.keys(project.data.links).length > 0 && (
          <div>
            <p class="meta-label">Links</p>
            <div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
              {project.data.links.github && (
                <a href={project.data.links.github} target="_blank" rel="noopener" class="btn btn-outline">
                  GitHub ↗
                </a>
              )}
              {project.data.links.tableau && (
                <a href={project.data.links.tableau} target="_blank" rel="noopener" class="btn btn-outline">
                  Tableau ↗
                </a>
              )}
              {project.data.links.demo && (
                <a href={project.data.links.demo} target="_blank" rel="noopener" class="btn btn-outline">
                  Live Demo ↗
                </a>
              )}
              {project.data.links.live && (
                <a href={project.data.links.live} target="_blank" rel="noopener" class="btn btn-primary">
                  View Live ↗
                </a>
              )}
            </div>
          </div>
        )}
      </div>
    </div>

    <div class="article-body">
      <Content />
    </div>

  </div>
</Base>

<style>
.back-link {
  display: inline-block;
  font-size: 0.875rem;
  color: var(--text-tertiary);
  margin-bottom: 2rem;
  transition: color 0.15s;
}
.back-link:hover { color: var(--text-primary); }

.project-header {
  margin-bottom: 2.5rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid var(--border);
}
.project-title {
  font-size: 2.25rem;
  margin: 0.75rem 0 0.75rem;
  line-height: 1.15;
}
.project-desc {
  font-size: 1.0625rem;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 1.5rem;
}
.project-meta {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.meta-label {
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 0.5rem;
}
</style>
